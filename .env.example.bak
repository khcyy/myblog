# Public / server-side app placeholders for local development
# Do not put real secrets in this file.
# Note: D1 binding name `DB` is configured in wrangler.toml, not in .env files.

# Cloudflare account id (used by drizzle/wrangler tooling)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# D1 database id (used by drizzle/wrangler tooling)
D1_DATABASE_ID=your_d1_database_id

# API token with D1 access (placeholder only)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# GitHub OAuth app client id (placeholder)
GITHUB_CLIENT_ID=your_github_client_id

# GitHub OAuth app client secret (placeholder)
GITHUB_CLIENT_SECRET=your_github_client_secret
