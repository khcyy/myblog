# Cloudflare local runtime variable placeholders for `wrangler dev`
# Copy to .dev.vars for local binding values.

# D1 binding name `DB` is declared in wrangler.toml [[d1_databases]].
# Do not define DB here; this file is not the source of D1 binding.

# Optional placeholders for local tooling
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
D1_DATABASE_ID=your_d1_database_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# GitHub OAuth placeholders for local development
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Session signing secret (min 16 chars)
AUTH_SESSION_SECRET=replace_with_a_long_random_secret

# Optional admin github id list, comma-separated
ADMIN_GITHUB_IDS=12345678
