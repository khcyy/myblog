---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { createProjectsRepository, getDbClientFromLocals } from '../../db';

const db = getDbClientFromLocals(Astro.locals as any);
const projects = db ? await createProjectsRepository(db).listAll() : [];
---

<AdminLayout title="后台 - 项目" currentPath={Astro.url.pathname}>
  <div style="display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.75rem;">
    <h2 style="margin: 0;">项目管理</h2>
    <a href="/admin/projects/new" style="display: inline-block; text-decoration: none; background: #2563eb; color: white; padding: 0.45rem 0.75rem; border-radius: 0.45rem; font-weight: 600;">新建项目</a>
  </div>

  {
    db ? null : <p style="margin: 0.4rem 0; color: #b91c1c;">数据库绑定缺失，无法加载项目列表。</p>
  }

  <div style="overflow-x: auto;">
    <table style="width: 100%; border-collapse: collapse; min-width: 780px;">
      <thead>
        <tr style="background: #f3f4f6;">
          <th style="text-align: left; padding: 0.55rem; border: 1px solid #e5e7eb;">ID</th>
          <th style="text-align: left; padding: 0.55rem; border: 1px solid #e5e7eb;">标题</th>
          <th style="text-align: left; padding: 0.55rem; border: 1px solid #e5e7eb;">Slug</th>
          <th style="text-align: left; padding: 0.55rem; border: 1px solid #e5e7eb;">状态</th>
          <th style="text-align: left; padding: 0.55rem; border: 1px solid #e5e7eb;">更新时间</th>
          <th style="text-align: left; padding: 0.55rem; border: 1px solid #e5e7eb;">操作</th>
        </tr>
      </thead>
      <tbody>
        {
          projects.length === 0 ? (
            <tr>
              <td colspan="6" style="padding: 0.75rem; border: 1px solid #e5e7eb; color: #6b7280;">暂无项目。</td>
            </tr>
          ) : (
            projects.map((project) => (
              <tr>
                <td style="padding: 0.55rem; border: 1px solid #e5e7eb;">{project.id}</td>
                <td style="padding: 0.55rem; border: 1px solid #e5e7eb;">{project.title}</td>
                <td style="padding: 0.55rem; border: 1px solid #e5e7eb;">{project.slug}</td>
                <td style="padding: 0.55rem; border: 1px solid #e5e7eb;">{project.status}</td>
                <td style="padding: 0.55rem; border: 1px solid #e5e7eb;">{project.updatedAt}</td>
                <td style="padding: 0.55rem; border: 1px solid #e5e7eb;">
                  <div style="display: flex; gap: 0.35rem; align-items: center; flex-wrap: wrap;">
                    <a href={`/admin/projects/${project.id}/edit`} style="text-decoration: none; border: 1px solid #cbd5e1; color: #1f2937; border-radius: 0.35rem; padding: 0.2rem 0.45rem;">编辑</a>

                    <button type="button" style="border: 1px solid #cbd5e1; background: #f8fafc; color: #1f2937; border-radius: 0.35rem; padding: 0.2rem 0.45rem; cursor: pointer;">
                      {project.status === 'published' ? '转草稿' : '发布'}
                    </button>

                    <button type="button" style="border: 1px solid #fecaca; background: #fee2e2; color: #991b1b; border-radius: 0.35rem; padding: 0.2rem 0.45rem; cursor: pointer;">
                      删除
                    </button>
                  </div>
                </td>
              </tr>
            ))
          )
        }
      </tbody>
    </table>
  </div>
</AdminLayout>
