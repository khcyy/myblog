---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const getCollectionAny = getCollection as unknown as (name: string) => Promise<any[]>;
  const allPosts = await getCollectionAny('blog');
  
  const uniqueTags = [...new Set(allPosts.flatMap((post) => post.data.tags || []))];

  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts
      .filter((post) => post.data.tags?.includes(tag))
      .sort((a, b) => {
        const dateA = new Date(a.data.date);
        const dateB = new Date(b.data.date);
        return dateB.getTime() - dateA.getTime();
      });
      
    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<Layout title={`标签: ${tag} - isishey blog`}>
  <div class="shell" style="max-width: 800px; margin-top: 40px;">
    
    <div class="topbar-inner" style="display: inline-flex; margin-bottom: 40px; padding: 10px 20px;">
      <a href="/#blog" style="font-weight: bold; color: var(--text);">&larr; 返回首页</a>
    </div>

    <header style="margin-bottom: 40px;">
      <h1 style="font-size: 36px; margin: 0 0 10px;">#{tag}</h1>
      <p style="color: var(--sub); font-size: 16px;">共找到 {posts.length} 篇文章</p>
    </header>

    <div class="list" style="display: flex; flex-direction: column; gap: 16px;">
      {posts.map((post: any) => (
        <article class="item" style="padding: 24px; border-radius: 20px; background: color-mix(in srgb, var(--paper) 100%, transparent); border: 1px solid var(--line);">
          <div>
            <h3 style="margin: 0 0 10px; font-size: 20px;">
              <a href={`/blog/${post.id.replace(/\.mdx?$/, '')}`}>{post.data.title}</a>
            </h3>
            <p style="margin: 0 0 12px; color: var(--sub); line-height: 1.6;">{post.data.description}</p>
            <div class="meta">
              <span>{new Date(post.data.date).toISOString().slice(0, 10)}</span>
              {post.data.tags?.map((t: string) => (
                <a href={`/tags/${t}`} class="tag" style={t === tag ? "background: var(--text); color: var(--bg);" : ""}>#{t}</a>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</Layout>