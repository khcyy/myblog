---
import { createCommentsRepository, createPostsRepository, getDbClientFromLocals } from '../../db';
import Layout from '../../layouts/Layout.astro';
import { renderRichContent } from '../../lib/render-content';
import { formatDateLongZh, formatDateTimeZh } from '../../lib/date';

export const prerender = false;

const slug = Astro.params.id ?? '';
const db = getDbClientFromLocals(Astro.locals as any);
const repo = db ? createPostsRepository(db) : null;
const commentsRepo = db ? createCommentsRepository(db) : null;
const row = repo && slug ? await repo.getPublishedBySlug(slug) : null;

if (!row) {
  Astro.response.status = 404;
}

const post = row
  ? {
      slug: row.slug,
      data: {
        title: row.title,
        tags: row.tags ?? [],
        date: row.publishedAt ?? row.updatedAt ?? row.createdAt,
        content: row.content ?? '',
        views: row.views ?? 0
      }
    }
  : null;

const comments = post && commentsRepo
  ? await commentsRepo.listApprovedByPostSlug(post.slug)
  : [];

const contentHtml = post ? renderRichContent(post.data.content ?? '') : '';

const headings: Array<{ slug: string; text: string; depth: number }> = [];

const dateStr = formatDateLongZh(post?.data.date);

const commentNotice = Astro.url.searchParams.get('commented') === '1'
  ? '评论已提交，等待审核。'
  : '';

const currentUser = (Astro.locals as any).currentUser;
const isLoggedIn = Boolean(currentUser);
const postSlug = post?.slug ?? '';
---

<Layout title={post ? `${post.data.title} - Blog` : '文章不存在 - Blog'}>
  <div class="shell page-shell">
    <div class="topbar">
      <div class="topbar-inner" style="justify-content: flex-start; padding: 12px 24px;">
        <a href="/#blog" style="font-weight: bold;">&larr; 返回首页</a>
      </div>
    </div>
    
    <div class="article-layout">
      <main class="panel article-panel" data-post-slug={postSlug}>
        {post ? (
          <>
            <header class="article-header">
              <h1>{post.data.title}</h1>
              <div class="meta">
                <span>{dateStr}</span>
                <span><span id="viewCount">{post.data.views ?? 0}</span> 次浏览</span>
                {post.data.tags?.length ? (
                  post.data.tags.map((tag: string) => (
                    <a href={`/blog/tag/${tag}`} class="tag">#{tag}</a>
                  ))
                ) : null}
              </div>
            </header>

            <article class="prose" set:html={contentHtml}></article>

            <!-- 本地全栈评论区 -->
            <section class="comments-section" style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--line);">
              <h3 style="margin-bottom: 1.5rem;">评论 / Comments</h3>
              {commentNotice ? (
                <p style="margin: 0 0 1rem; color: #0f766e;">{commentNotice}</p>
              ) : null}
              <div style="display: flex; flex-direction: column; gap: 1.5rem;">
                {comments.length === 0 ? (
                  <p style="color: var(--sub); font-size: 0.9rem;">暂无评论。</p>
                ) : (
                  comments.map((comment) => (
                    <div style="padding: 1.2rem; border: 1px solid var(--line); border-radius: 12px; background: color-mix(in srgb, var(--paper) 40%, transparent);">
                      <div style="display: flex; justify-content: space-between; margin-bottom: 0.8rem; align-items: center;">
                        <strong style="font-size: 1.05rem;">{comment.author ?? comment.nickname ?? '匿名'}</strong>
                        <span style="font-size: 0.8rem; color: var(--sub);">{formatDateTimeZh(comment.createdAt)}</span>
                      </div>
                      <p style="margin: 0; line-height: 1.6; white-space: pre-wrap; font-size: 0.95rem;">{comment.content}</p>
                    </div>
                  ))
                )}
              </div>

              {isLoggedIn ? (
                <form method="post" action="/api/comments/post" style="margin-top: 2rem; display: flex; flex-direction: column; gap: 1rem;">
                  <input type="hidden" name="postSlug" value={post.slug} />
                  <input type="hidden" name="redirectTo" value={Astro.url.pathname} />
                  <div style="font-size: 0.85rem; color: var(--sub);">已登录：{currentUser.username}（评论将显示为该账号）</div>
                  <textarea name="content" placeholder="分享你的看法..." required rows="4" style="padding: 0.8rem; border: 1px solid var(--line); border-radius: 8px; background: var(--paper); color: var(--text); outline: none; font-family: inherit; resize: vertical;"></textarea>
                  <div>
                    <button type="submit" style="padding: 0.6rem 1.5rem; border: none; border-radius: 8px; background: var(--text); color: var(--bg); font-weight: bold; cursor: pointer; transition: opacity 0.2s;">
                      提交评论
                    </button>
                  </div>
                </form>
              ) : (
                <div style="margin-top: 2rem; padding: 1rem; border: 1px dashed var(--line); border-radius: 10px; background: color-mix(in srgb, var(--paper) 70%, transparent);">
                  <p style="margin: 0 0 0.75rem; color: var(--sub);">登录 GitHub 后才可以发表评论。</p>
                  <a href="/api/auth/github/login?next=/" style="display: inline-flex; align-items: center; gap: 8px; padding: 0.55rem 1.1rem; border-radius: 8px; border: 1px solid var(--line); background: var(--paper); color: var(--text); font-weight: 600;">
                    去登录
                  </a>
                </div>
              )}
            </section>
          </>
        ) : (
          <section style="padding: 2rem 0;">
            <h1 style="margin: 0 0 0.75rem;">文章不存在或未发布</h1>
            <p style="margin: 0; color: var(--sub);">请返回列表查看其它内容。</p>
          </section>
        )}
      </main>

      {headings.length > 0 && (
        <aside class="toc-sidebar">
          <h3>目录 / On this page</h3>
          <nav class="toc-nav">
            {headings.map((heading: any) => (
              <a href={`#${heading.slug}`} class={`toc-depth-${heading.depth}`}>
                {heading.text}
              </a>
            ))}
          </nav>
        </aside>
      )}
    </div>
  </div>
</Layout>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const container = document.querySelector('[data-post-slug]');
    const slug = container?.getAttribute('data-post-slug') ?? '';
    if (!slug) return;

    const storageKey = `viewed-post-${slug}`;
    if (sessionStorage.getItem(storageKey)) return;
    sessionStorage.setItem(storageKey, '1');

    fetch('/api/views', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug })
    })
      .then((res) => res.json())
      .then((data) => {
        if (!data || typeof data.views !== 'number') return;
        const el = document.getElementById('viewCount');
        if (el) {
          el.textContent = String(data.views);
        }
      })
      .catch(() => {});
  });
</script>


