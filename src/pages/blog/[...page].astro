---
import { createPostsRepository, getDbClientFromLocals } from '../../db';
import Layout from '../../layouts/Layout.astro';

export const prerender = false;

const pageSize = 10;
const rawPageParam = Astro.params.page;
const pageParam = Array.isArray(rawPageParam) ? rawPageParam[0] : rawPageParam;
const requestedPage = Number.parseInt(pageParam ?? '1', 10);
const currentPage = Number.isFinite(requestedPage) && requestedPage > 0 ? requestedPage : 1;

const db = getDbClientFromLocals(Astro.locals as any);
const repo = db ? createPostsRepository(db) : null;

const totalPosts = repo ? await repo.countPublished() : 0;
const lastPage = Math.max(1, Math.ceil(totalPosts / pageSize));
const safeCurrentPage = Math.min(currentPage, lastPage);

const rows = repo ? await repo.listPublishedPage(safeCurrentPage, pageSize) : [];
const data = rows.map((post) => ({
  id: post.slug,
  data: {
    title: post.title,
    description: post.summary ?? '',
    date: post.publishedAt ?? '',
    tags: post.tags ?? []
  }
}));

const page = {
  currentPage: safeCurrentPage,
  lastPage,
  data,
  url: {
    prev: safeCurrentPage > 1 ? (safeCurrentPage === 2 ? '/blog' : `/blog/${safeCurrentPage - 1}`) : null,
    next: safeCurrentPage < lastPage ? `/blog/${safeCurrentPage + 1}` : null
  }
};
---

<Layout title={`笔记归档 - 第 ${page.currentPage} 页 - isishey blog`}>
  <div class="shell" style="max-width: 800px; margin-top: 40px;">
    
    <div class="topbar-inner" style="display: inline-flex; margin-bottom: 40px; padding: 10px 20px;">
      <a href="/#blog" style="font-weight: bold; color: var(--text);">&larr; 返回首页</a>
    </div>

    <header style="margin-bottom: 40px;">
      <h1 style="font-size: 36px; margin: 0 0 10px;">所有笔记 / Blog</h1>
      <p style="color: var(--sub); font-size: 16px;">记录与折腾，第 {page.currentPage} 页，共 {page.lastPage} 页</p>
    </header>

    <div class="list" style="display: flex; flex-direction: column; gap: 16px;">
      {page.data.map((post: any) => (
        <article class="item" style="padding: 24px; border-radius: 20px; background: color-mix(in srgb, var(--paper) 100%, transparent); border: 1px solid var(--line);">
          <div>
            <h3 style="margin: 0 0 10px; font-size: 20px;">
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
            </h3>
            <p style="margin: 0 0 12px; color: var(--sub); line-height: 1.6;">{post.data.description}</p>
            <div class="meta">
              <span>{post.data.date ? new Date(post.data.date).toISOString().slice(0, 10) : ''}</span>
              {post.data.tags?.map((t: string) => (
                <a href={`/blog/tag/${t}`} class="tag">#{t}</a>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- 分页导航 -->
    <div style="display: flex; justify-content: space-between; margin-top: 40px;">
      {page.url.prev ? <a href={page.url.prev} class="nav-link-out">&larr; 上一页</a> : <div></div>}
      {page.url.next ? <a href={page.url.next} class="nav-link-out">下一页 &rarr;</a> : <div></div>}
    </div>

  </div>
</Layout>