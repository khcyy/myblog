---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/home/SiteHeader.astro';
import HomeSection from '../components/home/HomeSection.astro';
import BlogSection from '../components/home/BlogSection.astro';
import ProjectsSection from '../components/home/ProjectsSection.astro';
import AboutSection from '../components/home/AboutSection.astro';
import FriendsSection from '../components/home/FriendsSection.astro';
import SiteFooter from '../components/common/SiteFooter.astro';

type BlogPreview = {
  id: string;
  title: string;
  description: string;
  date: string;
  tags: string[];
};

type ProjectPreview = {
  id: string;
  title: string;
  summary: string;
  date: string;
  stack: string[];
};

const getCollectionAny = getCollection as unknown as (name: string) => Promise<any[]>;

// 修复：安全获取 blog 文章（处理空日期）
const posts: BlogPreview[] = (await getCollectionAny('blog'))
  .filter(post => post.data.date) // 过滤掉没有日期的文章
  .sort((a, b) => {
    const dateA = new Date(a.data.date);
    const dateB = new Date(b.data.date);
    return dateB.getTime() - dateA.getTime();
  })
  .map((post) => ({
    id: post.id.replace(/\.mdx?$/, ''),
    title: post.data.title,
    description: post.data.description,
    date: new Date(post.data.date).toISOString().slice(0, 10),
    tags: post.data.tags || [],
  }))
  .slice(0, 5);

// 修复：安全获取 projects 项目（处理空日期）
const projects: ProjectPreview[] = (await getCollectionAny('projects'))
  .filter(project => project.data.date) // 过滤掉没有日期的项目
  .sort((a, b) => {
    const dateA = new Date(a.data.date);
    const dateB = new Date(b.data.date);
    return dateB.getTime() - dateA.getTime();
  })
  .map((project) => ({
    id: project.id.replace(/\.mdx?$/, ''),
    title: project.data.title,
    summary: project.data.summary,
    date: new Date(project.data.date).toISOString().slice(0, 10),
    stack: project.data.stack || [],
  }))
  .slice(0, 5);
---

<Layout title="isishey · mockup v5">

  <div class="shell">
    <SiteHeader />
    <HomeSection />
    <BlogSection posts={posts} />
    <ProjectsSection projects={projects} />
    <AboutSection />
    <FriendsSection />
    <SiteFooter />
  </div>
<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('themeToggle');
    btn?.addEventListener('click', () => {
      document.body.classList.toggle('dark');
    });
  });
</script>
</Layout>