---
import { createPostsRepository, createProjectsRepository, createSettingsRepository, getDbClientFromLocals } from '../db';
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/home/SiteHeader.astro';
import HomeSection from '../components/home/HomeSection.astro';
import BlogSection from '../components/home/BlogSection.astro';
import ProjectsSection from '../components/home/ProjectsSection.astro';
import AboutSection from '../components/home/AboutSection.astro';

export const prerender = false;

type BlogPreview = {
  id: string;
  title: string;
  description: string;
  date: string;
  tags: string[];
};

type ProjectPreview = {
  id: string;
  title: string;
  summary: string;
  date: string;
  stack: string[];
};

const db = getDbClientFromLocals(Astro.locals as any);
const postRepo = db ? createPostsRepository(db) : null;
const projectRepo = db ? createProjectsRepository(db) : null;
const settingsRepo = db ? createSettingsRepository(db) : null;

const defaultSettings = {
  siteName: 'isishey',
  siteDescription: '记录学习、项目、代码片段，以及日常生活中随时蹦出来的奇怪念头与感受。',
  homepageIntro: '',
  headerLogoUrl: '',
  heroLeftDecorUrl: '',
  heroAvatarUrl: '',
  heroRightDecorUrl: ''
};

const settings = settingsRepo ? await settingsRepo.getSingleton() : null;
const siteSettings = settings ?? defaultSettings;

const normalizeAssetUrl = (value: unknown) => {
  if (typeof value !== 'string') {
    return '';
  }
  const trimmed = value.trim();
  if (!trimmed) {
    return '';
  }
  if (trimmed.startsWith('/') || /^https?:\/\//i.test(trimmed)) {
    return trimmed;
  }
  return '';
};

const headerLogoUrl = normalizeAssetUrl(siteSettings.headerLogoUrl);
const heroLeftDecorUrl = normalizeAssetUrl(siteSettings.heroLeftDecorUrl);
const heroAvatarUrl = normalizeAssetUrl(siteSettings.heroAvatarUrl);
const heroRightDecorUrl = normalizeAssetUrl(siteSettings.heroRightDecorUrl);

const posts: BlogPreview[] = postRepo
  ? (await postRepo.listLatestPublished(5)).map((post) => {
      const dateSource = post.publishedAt ?? post.updatedAt ?? post.createdAt;
      return {
        id: post.slug,
        title: post.title,
        description: post.summary ?? '',
        date: dateSource ? new Date(dateSource).toISOString().slice(0, 10) : '',
        tags: post.tags ?? [],
      };
    })
  : [];

const projects: ProjectPreview[] = projectRepo
  ? (await projectRepo.listLatestPublished(5)).map((project) => {
      const dateSource = project.publishedAt ?? project.updatedAt ?? project.createdAt;
      return {
        id: project.slug,
        title: project.title,
        summary: project.summary ?? '',
        date: dateSource ? new Date(dateSource).toISOString().slice(0, 10) : '',
        stack: []
      };
    })
  : [];
---

<Layout title={`${siteSettings.siteName} · mockup v5`}>

  <div class="shell">
    <SiteHeader headerLogoUrl={headerLogoUrl} />
    <HomeSection
      siteName={siteSettings.siteName}
      siteDescription={siteSettings.siteDescription}
      homepageIntro={siteSettings.homepageIntro}
      heroLeftDecorUrl={heroLeftDecorUrl}
      heroAvatarUrl={heroAvatarUrl}
      heroRightDecorUrl={heroRightDecorUrl}
    />
    <BlogSection posts={posts} />
    <ProjectsSection projects={projects} />
    <AboutSection />
  </div>
<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('themeToggle');
    btn?.addEventListener('click', () => {
      document.body.classList.toggle('dark');
    });
  });
</script>
</Layout>