---
import Layout from '../../layouts/Layout.astro';
import { createProjectsRepository, getDbClientFromLocals } from '../../db';

export const prerender = false;

const slug = Astro.params.id;
const db = getDbClientFromLocals(Astro.locals as any);
const repo = db ? createProjectsRepository(db) : null;

if (!repo || !slug) {
  throw new Response('Not found', { status: 404 });
}

const project = await repo.getPublishedBySlug(slug);

if (!project) {
  throw new Response('Not found', { status: 404 });
}

const summary = project.summary ?? '';
const dateSource = project.publishedAt ?? project.updatedAt ?? project.createdAt;
const dateStr = dateSource
  ? new Date(dateSource).toLocaleDateString('zh-CN', {
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    })
  : '';
---

<Layout title={`${project.title} - Project`}>
  <div class="shell page-shell">
    <div class="topbar">
      <div class="topbar-inner" style="justify-content: flex-start; padding: 12px 24px;">
        <a href="/#projects" style="font-weight: bold;">&larr; 返回首页</a>
      </div>
    </div>
    
    <main class="panel article-panel">
      <header class="article-header">
        <h1>{project.title}</h1>
        <p class="summary">{summary}</p>
        <div class="meta">
          <span>{dateStr}</span>
        </div>
      </header>

      <article class="prose" style="white-space: pre-wrap;">
        {project.content}
      </article>

      <!-- Giscus 评论区 -->
      <section class="comments-section" style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--line);">
        <h3 style="margin-bottom: 1.5rem;">评论 / Comments</h3>
        <p style="color: var(--sub); font-size: 14px; margin-bottom: 2rem;">
          💡 提示：请前往 <a href="https://giscus.app/zh-CN" target="_blank" style="text-decoration: underline;">giscus.app</a> 并按照提示关联你的 GitHub 仓库，然后把下方 script 标签中的 data-repo、data-repo-id 等参数替换为你自己的。
        </p>
        <script src="https://giscus.app/client.js"
          data-repo="YOUR_GITHUB_NAME/YOUR_REPO_NAME"
          data-repo-id="YOUR_REPO_ID"
          data-category="Announcements"
          data-category-id="YOUR_CATEGORY_ID"
          data-mapping="pathname"
          data-strict="0"
          data-reactions-enabled="1"
          data-emit-metadata="0"
          data-input-position="bottom"
          data-theme="preferred_color_scheme"
          data-lang="zh-CN"
          crossorigin="anonymous"
          async>
        </script>
      </section>
    </main>
  </div>
</Layout>


