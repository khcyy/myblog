---
import Layout from '../../layouts/Layout.astro';
import { createCommentsRepository, createProjectsRepository, getDbClientFromLocals } from '../../db';

export const prerender = false;

const slug = Astro.params.id;
const db = getDbClientFromLocals(Astro.locals as any);
const repo = db ? createProjectsRepository(db) : null;
const commentsRepo = db ? createCommentsRepository(db) : null;

if (!repo || !slug) {
  throw new Response('Not found', { status: 404 });
}

const project = await repo.getPublishedBySlug(slug);

if (!project) {
  throw new Response('Not found', { status: 404 });
}

const comments = commentsRepo
  ? await commentsRepo.listApprovedByTarget('project', project.id)
  : [];

const summary = project.summary ?? '';
const dateSource = project.publishedAt ?? project.updatedAt ?? project.createdAt;
const dateStr = dateSource
  ? new Date(dateSource).toLocaleDateString('zh-CN', {
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    })
  : '';

const commentNotice = Astro.url.searchParams.get('commented') === '1'
  ? '评论已提交，等待审核。'
  : '';

const currentUser = (Astro.locals as any).currentUser;
const isLoggedIn = Boolean(currentUser);
---

<Layout title={`${project.title} - Project`}>
  <div class="shell page-shell">
    <div class="topbar">
      <div class="topbar-inner" style="justify-content: flex-start; padding: 12px 24px;">
        <a href="/#projects" style="font-weight: bold;">&larr; 返回首页</a>
      </div>
    </div>
    
    <main class="panel article-panel">
      <header class="article-header">
        <h1>{project.title}</h1>
        <p class="summary">{summary}</p>
        <div class="meta">
          <span>{dateStr}</span>
        </div>
      </header>

      <article class="prose" style="white-space: pre-wrap;">
        {project.content}
      </article>

      <section class="comments-section" style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--line);">
        <h3 style="margin-bottom: 1.5rem;">评论 / Comments</h3>
        {commentNotice ? (
          <p style="margin: 0 0 1rem; color: #0f766e;">{commentNotice}</p>
        ) : null}
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
          {comments.length === 0 ? (
            <p style="color: var(--sub); font-size: 0.9rem;">暂无评论。</p>
          ) : (
            comments.map((comment) => (
              <div style="padding: 1.2rem; border: 1px solid var(--line); border-radius: 12px; background: color-mix(in srgb, var(--paper) 40%, transparent);">
                <div style="display: flex; justify-content: space-between; margin-bottom: 0.8rem; align-items: center;">
                  <strong style="font-size: 1.05rem;">{comment.author ?? comment.nickname ?? '匿名'}</strong>
                  <span style="font-size: 0.8rem; color: var(--sub);">{new Date(comment.createdAt).toLocaleString()}</span>
                </div>
                <p style="margin: 0; line-height: 1.6; white-space: pre-wrap; font-size: 0.95rem;">{comment.content}</p>
              </div>
            ))
          )}
        </div>

        {isLoggedIn ? (
          <form method="post" action="/api/comments/post" style="margin-top: 2rem; display: flex; flex-direction: column; gap: 1rem;">
            <input type="hidden" name="targetType" value="project" />
            <input type="hidden" name="targetId" value={project.id} />
            <input type="hidden" name="redirectTo" value={Astro.url.pathname} />
            <div style="display: flex; gap: 1rem;">
              <input type="text" name="author" placeholder="昵称 (必填)" required style="flex: 1; padding: 0.8rem; border: 1px solid var(--line); border-radius: 8px; background: var(--paper); color: var(--text); outline: none; font-family: inherit;" />
              <input type="email" name="email" placeholder="邮箱 (选填)" style="flex: 1; padding: 0.8rem; border: 1px solid var(--line); border-radius: 8px; background: var(--paper); color: var(--text); outline: none; font-family: inherit;" />
            </div>
            <textarea name="content" placeholder="分享你的看法..." required rows="4" style="padding: 0.8rem; border: 1px solid var(--line); border-radius: 8px; background: var(--paper); color: var(--text); outline: none; font-family: inherit; resize: vertical;"></textarea>
            <div>
              <button type="submit" style="padding: 0.6rem 1.5rem; border: none; border-radius: 8px; background: var(--text); color: var(--bg); font-weight: bold; cursor: pointer; transition: opacity 0.2s;">
                提交评论
              </button>
            </div>
          </form>
        ) : (
          <div style="margin-top: 2rem; padding: 1rem; border: 1px dashed var(--line); border-radius: 10px; background: color-mix(in srgb, var(--paper) 70%, transparent);">
            <p style="margin: 0 0 0.75rem; color: var(--sub);">登录 GitHub 后才可以发表评论。</p>
            <a href="/api/auth/github/login?next=/" style="display: inline-flex; align-items: center; gap: 8px; padding: 0.55rem 1.1rem; border-radius: 8px; border: 1px solid var(--line); background: var(--paper); color: var(--text); font-weight: 600;">
              去登录
            </a>
          </div>
        )}
      </section>
    </main>
  </div>
</Layout>


