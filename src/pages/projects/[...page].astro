---
import Layout from '../../layouts/Layout.astro';
import ProjectCard from '../../components/projects/ProjectCard.astro';
import { createProjectsRepository, getDbClientFromLocals } from '../../db';

export const prerender = false;

const pageParam = Array.isArray(Astro.params.page) ? Astro.params.page[0] : Astro.params.page;
const currentPage = pageParam ? Number(pageParam) : 1;
const pageSize = 10;

const db = getDbClientFromLocals(Astro.locals as any);
const repo = db ? createProjectsRepository(db) : null;
const total = repo ? await repo.countPublished() : 0;
const lastPage = Math.max(1, Math.ceil(total / pageSize));

if (!Number.isFinite(currentPage) || currentPage <= 0) {
  throw new Response('Not found', { status: 404 });
}

if (total > 0 && currentPage > lastPage) {
  throw new Response('Not found', { status: 404 });
}

const rows = repo ? await repo.listPublishedPage(currentPage, pageSize) : [];
const data = rows.map((project) => {
  const dateSource = project.publishedAt ?? project.updatedAt ?? project.createdAt;
  return {
    id: project.slug,
    title: project.title,
    summary: project.summary ?? '',
    date: dateSource ?? '',
    stack: [] as string[],
    views: project.views ?? 0
  };
});

const page = {
  data,
  currentPage,
  lastPage,
  url: {
    prev: currentPage > 1 ? (currentPage === 2 ? '/projects' : `/projects/${currentPage - 1}`) : null,
    next: currentPage < lastPage ? `/projects/${currentPage + 1}` : null
  }
};
---

<Layout title={`项目归档 - 第 ${page.currentPage} 页 - isishey blog`}>
  <div class="shell" style="max-width: 800px; margin-top: 40px;">
    
    <div class="topbar-inner" style="display: inline-flex; margin-bottom: 40px; padding: 10px 20px;">
      <a href="/#projects" style="font-weight: bold; color: var(--text);">&larr; 返回首页</a>
    </div>

    <header style="margin-bottom: 40px;">
      <h1 style="font-size: 36px; margin: 0 0 10px;">所有项目 / Projects</h1>
      <p style="color: var(--sub); font-size: 16px;">代码与实践记录，第 {page.currentPage} 页，共 {page.lastPage} 页</p>
    </header>

    <div class="list" style="display: flex; flex-direction: column; gap: 16px;">
      {page.data.map((project: any) => (
        <ProjectCard
          id={project.id}
          title={project.title}
          summary={project.summary}
          date={project.date}
          stack={project.stack ?? []}
          views={project.views ?? 0}
        />
      ))}
    </div>

    {page.data.length === 0 ? (
      <p style="margin-top: 24px; color: var(--sub);">暂无已发布项目。</p>
    ) : null}

    <!-- 分页导航 -->
    <div style="display: flex; justify-content: space-between; margin-top: 40px;">
      {page.url.prev ? <a href={page.url.prev} class="nav-link-out">&larr; 上一页</a> : <div></div>}
      {page.url.next ? <a href={page.url.next} class="nav-link-out">下一页 &rarr;</a> : <div></div>}
    </div>

  </div>
</Layout>