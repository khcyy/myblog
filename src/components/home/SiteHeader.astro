---
import { siteConfig } from '../../data/siteData';

const {
  headerLogoUrl = '',
  user = null
} = Astro.props;

const headerLogoSrc = headerLogoUrl || '/images/logo.png';
const loginHref = '/api/auth/github/login?next=/';
const avatarSrc = user?.avatarUrl || headerLogoSrc;
const isAdmin = user?.role === 'admin';
---

<header class="topbar">
  <div class="topbar-inner">
    <div class="brand">
      <div class="brand-mark"><img src={headerLogoSrc} alt="logo"></div>
      <div class="brand-text">
        <strong>{siteConfig.title}</strong>
        <span>notes · projects · feelings</span>
      </div>
    </div>
    <div class="nav-tools">
      <nav class="nav">
        <a href="#home">home</a>
        <a href="#blog">blog</a>
        <a href="#projects">projects</a>
        <a href="#about">about</a>
        <a href="/search" style="color: var(--text); display: inline-flex; align-items: center; justify-content: center;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </a>
      </nav>
      {user ? (
        <details class="user-menu">
          <summary class="user-menu-trigger" aria-label="用户菜单">
            <img src={avatarSrc} alt="用户头像" />
          </summary>
          <div class="user-menu-panel">
            <div class="user-menu-meta">
              <div class="user-menu-name">{user.username}</div>
              <div class="user-menu-id">{user.githubId}</div>
            </div>
            {isAdmin ? (
              <a class="user-menu-link" href="/admin">后台</a>
            ) : null}
            <a class="user-menu-link" href="/api/auth/logout">退出登录</a>
          </div>
        </details>
      ) : (
        <a class="nav-link-out" href={loginHref}>登录</a>
      )}
      <button class="theme-btn" id="themeToggle" aria-label="切换日夜模式">
        <span class="crescent"></span>
      </button>
    </div>
  </div>
</header>
