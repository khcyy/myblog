---
import "../../styles/home-hero.css";
---

<section class="home-hero" aria-label="首页主视觉区域">
  <div class="home-hero-left" aria-hidden="true">
    <img src="/images/left-handwrite.png" alt="isishey 手写字样" class="isishey-mark" />
  </div>

  <div class="home-hero-center">
    <article class="profile-card">
      <img src="/images/center-card.png" alt="个人简介" class="profile-avatar-card" style="width:100%; height:auto;" />
    </article>
  </div>

  <div class="home-hero-right" aria-hidden="true">
    <img src="/images/flowers.png" alt="" class="flower flower-one" />
    <img src="/images/logo.png" alt="" class="flower flower-two" />
  </div>

  <div class="earth-base" aria-hidden="true"></div>
</section>
