---
import { socialLinks } from '../../data/siteData';

const defaultIntro = '记录学习、项目、代码片段，以及日常生活中随时蹦出来的奇怪念头与感受。';

const {
  siteName = 'isishey',
  siteDescription = '',
  homepageIntro = '',
  heroLeftDecorUrl = '',
  heroAvatarUrl = '',
  heroRightDecorUrl = ''
} = Astro.props;

const introText = [siteDescription, homepageIntro].filter(Boolean).join(' ') || defaultIntro;
const heroLeftDecorSrc = heroLeftDecorUrl || '/images/left-handwrite.png';
const heroAvatarSrc = heroAvatarUrl || '/images/center-card.png';
const heroRightDecorSrc = heroRightDecorUrl || '/images/flowers.png';
const githubLink = socialLinks.find((link) => link.name === 'GitHub')?.href || 'https://github.com';
const emailAddress = socialLinks.find((link) => link.name === 'Email')?.href?.replace('mailto:', '') || 'hello@example.com';
---

<section class="panel home" id="home">
  <div class="earth-base" aria-hidden="true"></div>

  <div class="home-inner-3col">
    <div class="home-left">
      <img src={heroLeftDecorSrc} alt="isishey 手写字样" />
    </div>

    <div class="home-center">
      <article class="profile-card-new">
        <div class="avatar"><img src={heroAvatarSrc} alt="头像" /></div>
        <h2>{siteName}</h2>
        <p>{introText}</p>
        <div class="profile-links-new">
          <button class="email-copy-btn" id="emailCopyBtn" aria-label="复制邮箱" data-email={emailAddress}><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18v12H3z"></path><path d="M4 7l8 6 8-6"></path></svg></button>
          <a href={githubLink} class="fill" aria-label="GitHub" target="_blank" rel="noopener noreferrer"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.21.68-.48v-1.69c-2.78.6-3.37-1.18-3.37-1.18-.46-1.15-1.1-1.45-1.1-1.45-.91-.62.06-.61.06-.61 1 .07 1.53 1.03 1.53 1.03.9 1.53 2.35 1.09 2.92.83.09-.65.35-1.1.63-1.35-2.22-.25-4.56-1.11-4.56-4.93 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.03A9.53 9.53 0 0 1 12 6.8c.85 0 1.71.11 2.51.33 1.91-1.3 2.75-1.03 2.75-1.03.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.83-2.35 4.67-4.58 4.92.36.31.68.91.68 1.84v2.72c0 .27.18.58.69.48A10 10 0 0 0 12 2z"></path></svg></a>
        </div>
      </article>
    </div>

    <div class="home-right">
      <img src={heroRightDecorSrc} alt="两朵黄色小花" />
    </div>
  </div>

  <div class="email-toast" id="emailToast">您已复制开发者的邮箱，快去联系吧~</div>
</section>

<script>
  const btn = document.getElementById('emailCopyBtn');
  const toast = document.getElementById('emailToast');
  let timer;

  btn.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(btn.dataset.email);
      toast.classList.add('show');
      clearTimeout(timer);
      timer = setTimeout(() => toast.classList.remove('show'), 2500);
    } catch {
      // clipboard API not available
    }
  });
</script>
