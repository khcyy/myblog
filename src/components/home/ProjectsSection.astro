---
import ProjectCard from '../projects/ProjectCard.astro';

interface Props {
  projects: {
    id: string;
    title: string;
    summary: string;
    date: string;
    stack?: string[];
    views?: number;
  }[];
}

const { projects } = Astro.props;
---

<section class="panel section" id="projects">
  <div class="section-head" style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 24px;">
    <h2>projects</h2>
    <a href="/projects" class="nav-link-out" style="font-size: 14px; display: inline-flex; align-items: center; gap: 4px; padding: 4px 12px; border-radius: 20px; background: var(--line); color: var(--text); text-decoration: none; transition: 0.2s;">
      查看全部项目 &rarr;
    </a>
  </div>
  <div class="list">
    {projects.map((project) => (
      <ProjectCard
        id={project.id}
        title={project.title}
        summary={project.summary}
        date={project.date}
        stack={project.stack ?? []}
        views={project.views ?? 0}
      />
    ))}
  </div>
</section>
