---
const {
  label,
  name,
  initialValue = '',
  required = false,
  help = '',
  uploadSlot = 'general'
} = Astro.props;
---

<label class="rich-editor" data-rich-editor data-upload-slot={uploadSlot}>
  <span class="rich-editor-label">{label}</span>
  <div class="rich-editor-toolbar" role="toolbar">
    <button type="button" class="rich-editor-btn" data-cmd="bold"><strong>B</strong></button>
    <button type="button" class="rich-editor-btn" data-cmd="italic"><em>I</em></button>
    <button type="button" class="rich-editor-btn" data-cmd="underline"><span style="text-decoration: underline;">U</span></button>
    <button type="button" class="rich-editor-btn" data-cmd="strikeThrough"><span style="text-decoration: line-through;">S</span></button>
    <button type="button" class="rich-editor-btn" data-cmd="formatBlock" data-value="H2">H2</button>
    <button type="button" class="rich-editor-btn" data-cmd="formatBlock" data-value="H3">H3</button>
    <button type="button" class="rich-editor-btn" data-cmd="formatBlock" data-value="BLOCKQUOTE">引用</button>
    <button type="button" class="rich-editor-btn" data-cmd="insertUnorderedList">无序</button>
    <button type="button" class="rich-editor-btn" data-cmd="insertOrderedList">有序</button>
    <button type="button" class="rich-editor-btn" data-action="link">链接</button>
    <button type="button" class="rich-editor-btn" data-action="image">图片</button>
    <input type="file" accept="image/*" hidden data-image-input />
  </div>
  <div class="rich-editor-surface" contenteditable="true" data-editor></div>
  <textarea name={name} class="rich-editor-input" hidden data-editor-input required={required}></textarea>
  <textarea class="rich-editor-initial" hidden data-editor-initial>{initialValue}</textarea>
  <p class="rich-editor-status" data-editor-status></p>
  {help ? <p class="rich-editor-help">{help}</p> : null}
</label>

<style is:global>
  .rich-editor {
    display: grid;
    gap: 0.45rem;
    font-weight: 600;
    color: #111827;
  }
  .rich-editor-label {
    font-weight: 600;
  }
  .rich-editor-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .rich-editor-btn {
    border: 1px solid #d1d5db;
    background: white;
    padding: 0.25rem 0.5rem;
    border-radius: 0.35rem;
    font-size: 0.85rem;
    cursor: pointer;
  }
  .rich-editor-btn:active {
    transform: translateY(1px);
  }
  .rich-editor-surface {
    min-height: 320px;
    padding: 0.75rem 0.85rem;
    border: 1px solid #d1d5db;
    border-radius: 0.45rem;
    font-weight: 400;
    font-family: inherit;
    line-height: 1.7;
    background: white;
    max-height: 70vh;
    overflow: auto;
  }
  .rich-editor-surface img {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 20px auto;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow);
  }
  .rich-editor-surface .rte-image {
    position: relative;
    max-width: 100%;
    min-width: 160px;
    margin: 24px auto;
    display: block;
  }
  .rich-editor-surface .rte-image[data-selected="true"] {
    outline: 2px solid #93c5fd;
    outline-offset: 2px;
  }
  .rich-editor-surface .rte-image img {
    width: 100%;
    height: auto;
    display: block;
    margin: 0;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow);
  }
  .rich-editor-surface .rte-handle {
    position: absolute;
    width: 12px;
    height: 12px;
    border-radius: 2px;
    background: #ffffff;
    border: 1px solid #60a5fa;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
    display: none;
    touch-action: none;
  }
  .rich-editor-surface .rte-image[data-selected="true"] .rte-handle {
    display: block;
  }
  .rich-editor-surface .rte-handle--nw { top: -6px; left: -6px; cursor: nwse-resize; }
  .rich-editor-surface .rte-handle--ne { top: -6px; right: -6px; cursor: nesw-resize; }
  .rich-editor-surface .rte-handle--sw { bottom: -6px; left: -6px; cursor: nesw-resize; }
  .rich-editor-surface .rte-handle--se { bottom: -6px; right: -6px; cursor: nwse-resize; }
  .rich-editor-surface:focus {
    outline: 2px solid #93c5fd;
    border-color: #60a5fa;
  }
  .rich-editor-status,
  .rich-editor-help {
    margin: 0;
    font-size: 0.85rem;
    color: #6b7280;
    font-weight: 400;
  }
</style>

<script>
  // @ts-nocheck
  /** @type {NodeListOf<HTMLElement>} */
  const wrappers = document.querySelectorAll('[data-rich-editor]');

  wrappers.forEach((wrapper) => {
    const editor = /** @type {HTMLDivElement | null} */ (wrapper.querySelector('[data-editor]'));
    const input = /** @type {HTMLTextAreaElement | null} */ (wrapper.querySelector('[data-editor-input]'));
    const initialEl = /** @type {HTMLTextAreaElement | null} */ (wrapper.querySelector('[data-editor-initial]'));
    const status = /** @type {HTMLParagraphElement | null} */ (wrapper.querySelector('[data-editor-status]'));
    const imageButton = /** @type {HTMLButtonElement | null} */ (wrapper.querySelector('[data-action="image"]'));
    const imageInput = /** @type {HTMLInputElement | null} */ (wrapper.querySelector('[data-image-input]'));
    const toolbarButtons = /** @type {NodeListOf<HTMLButtonElement>} */ (wrapper.querySelectorAll('[data-cmd], [data-action]'));
    const slot = wrapper.getAttribute('data-upload-slot') || 'general';

    if (!editor || !input || !initialEl) {
      return;
    }

    const initial = initialEl.value || '';
    const hasHtml = /<\/?[a-z][\s\S]*>/i.test(initial);

    if (initial) {
      if (hasHtml) {
        editor.innerHTML = initial;
      } else {
        editor.textContent = initial;
      }
    }

    input.value = initial;

    function getEditorContentWidth() {
      const styles = window.getComputedStyle(editor);
      const paddingLeft = Number.parseFloat(styles.paddingLeft) || 0;
      const paddingRight = Number.parseFloat(styles.paddingRight) || 0;
      return Math.max(0, editor.clientWidth - paddingLeft - paddingRight);
    }

    /** @param {HTMLElement} figure */
    function ensureHandles(figure) {
      if (figure.querySelector('.rte-handle')) {
        return;
      }
      const directions = ['nw', 'ne', 'sw', 'se'];
      directions.forEach((dir) => {
        const handle = document.createElement('span');
        handle.className = `rte-handle rte-handle--${dir}`;
        handle.setAttribute('data-rte-handle', dir);
        figure.appendChild(handle);
      });
    }

    /**
     * @param {HTMLElement} figure
     * @param {HTMLImageElement} img
     */
    function applyDefaultSize(figure, img) {
      const isAuto = figure.dataset.rteAuto === '1';
      if (figure.style.width && !isAuto) {
        return;
      }
      const maxWidth = getEditorContentWidth();
      const naturalWidth = img.naturalWidth || maxWidth;
      const safeWidth = Math.min(maxWidth || naturalWidth, naturalWidth || maxWidth);
      const targetWidth = Math.max(160, safeWidth || 160);
      figure.style.width = `${targetWidth}px`;
      figure.dataset.rteAuto = '1';
    }

    /** @param {HTMLElement} figure */
    function setupImageFigure(figure) {
      figure.classList.add('rte-image');
      figure.setAttribute('contenteditable', 'false');
      const img = /** @type {HTMLImageElement | null} */ (figure.querySelector('img'));
      if (!img) {
        return;
      }
      img.style.width = '100%';
      img.style.height = 'auto';
      ensureHandles(figure);
      applyDefaultSize(figure, img);
      if (!img.complete) {
        img.addEventListener('load', () => applyDefaultSize(figure, img), { once: true });
      }
    }

    /** @param {HTMLImageElement} img */
    function wrapImageNode(img) {
      const figure = document.createElement('figure');
      const link = img.closest('a');

      if (link && link.parentElement) {
        const parent = link.parentElement;
        parent.replaceChild(figure, link);
        figure.appendChild(link);
      } else if (img.parentElement) {
        img.parentElement.replaceChild(figure, img);
        figure.appendChild(img);
      }

      setupImageFigure(figure);
      return figure;
    }

    function normalizeImages() {
      const images = /** @type {HTMLImageElement[]} */ (Array.from(editor.querySelectorAll('img')));
      images.forEach((img) => {
        const figure = img.closest('.rte-image');
        if (figure) {
          setupImageFigure(figure);
          return;
        }
        wrapImageNode(img);
      });
    }

    function serializeContent() {
      const clone = /** @type {HTMLElement} */ (editor.cloneNode(true));
      clone.querySelectorAll('.rte-handle').forEach((handle) => handle.remove());
      clone.querySelectorAll('.rte-image').forEach((figure) => {
        figure.removeAttribute('data-selected');
        figure.removeAttribute('contenteditable');
      });
      return clone.innerHTML.trim();
    }

    const form = wrapper.closest('form');
    if (form) {
      form.addEventListener('submit', () => {
        input.value = serializeContent();
      });
    }

    /**
     * @param {string} message
     * @param {string=} color
     */
    function setStatus(message, color) {
      if (!status) {
        return;
      }
      status.textContent = message;
      status.style.color = color || '#6b7280';
    }

    /** @param {string} url */
    function createImageFigure(url) {
      const figure = document.createElement('figure');
      const img = document.createElement('img');
      img.src = url;
      img.alt = 'image';
      figure.appendChild(img);
      setupImageFigure(figure);
      return figure;
    }

    /** @param {string} url */
    function insertImage(url) {
      editor.focus();
      const figure = createImageFigure(url);
      const spacer = document.createElement('p');
      spacer.innerHTML = '<br />';
      const selection = window.getSelection();
      if (!selection || selection.rangeCount === 0) {
        editor.appendChild(figure);
        editor.appendChild(spacer);
        return;
      }
      const range = selection.getRangeAt(0);
      range.deleteContents();
      range.insertNode(figure);
      figure.insertAdjacentElement('afterend', spacer);
      range.setStart(spacer, 0);
      range.collapse(true);
      selection.removeAllRanges();
      selection.addRange(range);
    }

    /** @param {File} file */
    async function uploadImage(file) {
      const formData = new FormData();
      formData.append('file', file);
      formData.append('slot', slot);

      const response = await fetch('/api/admin/assets/upload', {
        method: 'POST',
        body: formData
      });

      let result = null;
      try {
        result = await response.json();
      } catch {
        result = null;
      }

      if (!response.ok || !result?.ok) {
        const message = result?.error || '上传失败，请稍后重试。';
        throw new Error(message);
      }

      return result.url;
    }

    toolbarButtons.forEach((button) => {
      button.addEventListener('click', async (event) => {
        event.preventDefault();

        const cmd = button.getAttribute('data-cmd');
        const action = button.getAttribute('data-action');
        const value = button.getAttribute('data-value');

        if (cmd) {
          editor.focus();
          document.execCommand(cmd, false, value || undefined);
          return;
        }

        if (action === 'link') {
          editor.focus();
          const url = window.prompt('请输入链接地址');
          if (url) {
            document.execCommand('createLink', false, url.trim());
          }
          return;
        }

        if (action === 'image' && imageInput) {
          imageInput.click();
        }
      });
    });

    if (imageInput) {
      imageInput.addEventListener('change', async () => {
        const file = imageInput.files?.[0];
        if (!file) {
          return;
        }

        setStatus('上传图片中...', '#6b7280');

        try {
          const url = await uploadImage(file);
          insertImage(url);
          setStatus('图片已插入。', '#0f766e');
        } catch (error) {
          const message = error instanceof Error ? error.message : '上传失败';
          setStatus(message, '#b91c1c');
        } finally {
          imageInput.value = '';
        }
      });
    }

    normalizeImages();

    /** @type {number | null} */
    let normalizeTimer = null;
    editor.addEventListener('input', () => {
      if (normalizeTimer) {
        return;
      }
      normalizeTimer = window.requestAnimationFrame(() => {
        normalizeImages();
        normalizeTimer = null;
      });
    });

    /** @type {HTMLElement | null} */
    let activeFigure = null;
    /**
     * @typedef {{
     *  figure: HTMLElement,
     *  startX: number,
     *  startY: number,
     *  startWidth: number,
     *  startHeight: number,
     *  ratio: number,
     *  dir: string,
     *  pointerId: number,
     *  handle: HTMLElement
     * }} ResizeState
     */
    /** @type {ResizeState | null} */
    let resizeState = null;

    function clearSelection() {
      if (activeFigure) {
        activeFigure.removeAttribute('data-selected');
        activeFigure = null;
      }
    }

    /** @param {HTMLElement} figure */
    function selectFigure(figure) {
      if (activeFigure && activeFigure !== figure) {
        activeFigure.removeAttribute('data-selected');
      }
      activeFigure = figure;
      if (activeFigure) {
        activeFigure.setAttribute('data-selected', 'true');
      }
    }

    /**
     * @param {HTMLElement} handle
     * @param {PointerEvent} event
     */
    function startResize(handle, event) {
      const figure = /** @type {HTMLElement | null} */ (handle.closest('.rte-image'));
      if (!figure) {
        return;
      }
      const img = /** @type {HTMLImageElement | null} */ (figure.querySelector('img'));
      if (!img) {
        return;
      }
      const rect = figure.getBoundingClientRect();
      const ratio = img.naturalWidth && img.naturalHeight ? img.naturalWidth / img.naturalHeight : rect.width / rect.height;
      resizeState = {
        figure,
        startX: event.clientX,
        startY: event.clientY,
        startWidth: rect.width,
        startHeight: rect.height,
        ratio: ratio || 1,
        dir: handle.getAttribute('data-rte-handle') || 'se',
        pointerId: event.pointerId,
        handle
      };
      selectFigure(figure);
      if (handle.setPointerCapture) {
        handle.setPointerCapture(event.pointerId);
      }
      document.body.style.userSelect = 'none';
    }

    /** @param {PointerEvent} event */
    function updateResize(event) {
      if (!resizeState) {
        return;
      }
      const { figure, startX, startY, startWidth, startHeight, ratio, dir } = resizeState;
      const dx = event.clientX - startX;
      const dy = event.clientY - startY;
      const isEast = dir.includes('e');
      const isSouth = dir.includes('s');
      const scaleX = (startWidth + (isEast ? dx : -dx)) / startWidth;
      const scaleY = (startHeight + (isSouth ? dy : -dy)) / startHeight;
      let scale = Math.max(scaleX, scaleY);
      if (!Number.isFinite(scale) || scale <= 0) {
        scale = 0.1;
      }
      const minWidth = 160;
      const maxWidth = Math.max(minWidth, getEditorContentWidth());
      let nextWidth = startWidth * scale;
      nextWidth = Math.min(Math.max(nextWidth, minWidth), maxWidth);
      const nextHeight = nextWidth / ratio;
      figure.style.width = `${nextWidth}px`;
      figure.style.height = `${nextHeight}px`;
      figure.dataset.rteAuto = '0';
    }

    function stopResize() {
      if (resizeState) {
        resizeState.figure.style.height = '';
        const handle = resizeState.handle;
        if (handle && handle.releasePointerCapture && resizeState.pointerId != null) {
          try {
            handle.releasePointerCapture(resizeState.pointerId);
          } catch {}
        }
      }
      resizeState = null;
      document.body.style.userSelect = '';
    }

    editor.addEventListener(
      'pointerdown',
      /** @param {PointerEvent} event */ (event) => {
        if (!(event.target instanceof Element)) {
          clearSelection();
          return;
        }
        const handle = /** @type {HTMLElement | null} */ (event.target.closest('[data-rte-handle]'));
        if (handle && editor.contains(handle)) {
          event.preventDefault();
          event.stopPropagation();
          startResize(handle, event);
          return;
        }

        const figure = /** @type {HTMLElement | null} */ (event.target.closest('.rte-image'));
        if (figure && editor.contains(figure)) {
          selectFigure(figure);
          return;
        }

        clearSelection();
      },
      true
    );

    document.addEventListener('pointerdown', /** @param {PointerEvent} event */ (event) => {
      if (!(event.target instanceof Node)) {
        return;
      }
      if (!wrapper.contains(event.target)) {
        clearSelection();
      }
    });

    document.addEventListener('pointermove', /** @param {PointerEvent} event */ (event) => {
      if (resizeState && resizeState.pointerId === event.pointerId) {
        updateResize(event);
      }
    });

    document.addEventListener('pointerup', /** @param {PointerEvent} event */ (event) => {
      if (resizeState && resizeState.pointerId === event.pointerId) {
        stopResize();
      }
    });

    editor.addEventListener('paste', /** @param {ClipboardEvent} event */ async (event) => {
      const items = event.clipboardData ? Array.from(event.clipboardData.items) : [];
      const images = items
        .filter((item) => item.kind === 'file' && item.type.startsWith('image/'))
        .map((item) => item.getAsFile())
        .filter(Boolean);

      if (images.length === 0) {
        return;
      }

      event.preventDefault();
      setStatus('正在上传粘贴的图片...', '#6b7280');

      for (const file of images) {
        try {
          const url = await uploadImage(file);
          insertImage(url);
        } catch (error) {
          const message = error instanceof Error ? error.message : '上传失败';
          setStatus(message, '#b91c1c');
          return;
        }
      }

      setStatus('图片已插入。', '#0f766e');
    });
  });
</script>
