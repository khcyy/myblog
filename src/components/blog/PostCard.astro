---
interface Props {
  id: string;
  title: string;
  description: string;
  date: string;
  tags: string[];
  views?: number;
  pinned?: boolean;
  content?: string;
}

const { id, title, description, date, tags, views = 0, pinned = false, content = '' } = Astro.props;

function calcReadingTime(raw: string): number {
  if (!raw) return 1;
  const text = raw.replace(/<[^>]*>/g, '').replace(/&nbsp;/g, ' ');
  const chineseChars = (text.match(/[一-鿿㐀-䶿豈-﫿]/g) || []).length;
  const rest = text.replace(/[一-鿿㐀-䶿豈-﫿]/g, ' ');
  const englishWords = rest.split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.ceil(chineseChars / 300 + englishWords / 200));
}

const readingTime = calcReadingTime(content);
const isPopular = views >= 100;
const displayDate = date ? new Date(date).toISOString().slice(0, 10) : '';

const cardClasses = [
  'item',
  'card-hoverable',
  pinned ? 'card-pinned' : '',
  isPopular && !pinned ? 'card-popular' : ''
].filter(Boolean).join(' ');
---

<article class={cardClasses}>
  <a href={`/blog/${id}`} class="card-link-overlay" aria-label={title}></a>

  {
    pinned || isPopular ? (
      <div class="card-badges">
        {pinned ? (
          <span class="card-badge card-badge-pinned">
            <svg viewBox="0 0 24 24"><path d="M12 2L15 9H22L16 14L18 21L12 17L6 21L8 14L2 9H9Z"/></svg>
            置顶
          </span>
        ) : <span></span>}
        {isPopular ? (
          <span class="card-badge card-badge-popular">
            <svg viewBox="0 0 24 24"><path d="M12 2c-1.5 4-3.5 6.5-5.5 8.5-2.5 2.5-4.5 4-4.5 6.5 0 3 2.5 5 5 5 2 0 3.5-1 5-3 1.5 2 3 3 5 3 2.5 0 5-2 5-5 0-2.5-2-4-4.5-6.5-2-2-4-4.5-5.5-8.5z"/></svg>
            热门
          </span>
        ) : null}
      </div>
    ) : null
  }

  <div>
    <h3>{title}</h3>
    <p>{description}</p>

    <div class="card-meta-icons">
      <span class="card-meta-item">
        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        {displayDate || '--'}
      </span>

      {tags.length > 0 ? (
        <span class="card-meta-item">
          <svg viewBox="0 0 24 24"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          <span class="card-meta-tags">
            {tags.map((tag: string) => (
              <a href={`/blog/tag/${tag}`} class="tag card-tag-link">{tag}</a>
            ))}
          </span>
        </span>
      ) : null}

      <span class="card-meta-item">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        {readingTime} 分钟
      </span>

      <span class="card-meta-item">
        <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
        {views} 次浏览
      </span>
    </div>
  </div>

  <div class="card-arrow">
    <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
  </div>
</article>

<style>
.card-link-overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
}
.card-link-overlay::after {
  content: '';
  position: absolute;
  inset: 0;
}
.card-tag-link {
  position: relative;
  z-index: 2;
}
.card-tag-link:hover {
  background: var(--text);
  color: var(--bg);
  text-decoration: none;
}
</style>
